+        "улиц" in lower || "двор" in lower -> Icons.Default.Park
+        "техн" in lower || "котельн" in lower -> Icons.Default.Build
+        "детск" in lower -> Icons.Default.ChildCare
+        else -> Icons.Default.Room
+    }
